---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../Breadcrumb.astro';
import { getLocalizedPath, type Lang } from '../../i18n/ui';
import { getAboutContent } from '../../i18n/content/about';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const c = getAboutContent(lang);

// JSON-LD structured data for Person schema (optimized for recruiters)
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Alexandru Pruteanu",
  "alternateName": "Alex Pruteanu",
  "url": "https://alexpruteanu.cloud",
  "image": "https://alexpruteanu.cloud/width=3840.webp",
  "jobTitle": "DevOps Engineer",
  "worksFor": {
    "@type": "Organization",
    "name": "Yopeso"
  },
  "sameAs": [
    "https://github.com/xander1421",
    "https://linkedin.com/in/alexandru-prt",
    "https://alexpruteanu.cloud"
  ],
  "email": "alexpruteanu@hotmail.com",
  "knowsAbout": [
    "DevOps",
    "Cloud Infrastructure",
    "AWS",
    "Google Cloud Platform",
    "Kubernetes",
    "Docker",
    "Terraform",
    "Infrastructure as Code",
    "CI/CD",
    "Jenkins",
    "GitHub Actions",
    "Ansible",
    "Helm",
    "Site Reliability Engineering",
    "Monitoring",
    "Observability",
    "Python",
    "Bash",
    "PostgreSQL",
    "Redis",
    "Security",
    "IAM",
    "RBAC",
    "Secrets Management",
    "SSL/TLS",
    "Encryption"
  ],
  "knowsLanguage": [
    {
      "@type": "Language",
      "name": "Romanian",
      "alternateName": "ro"
    },
    {
      "@type": "Language",
      "name": "English",
      "alternateName": "en"
    },
    {
      "@type": "Language",
      "name": "Portuguese",
      "alternateName": "pt"
    },
    {
      "@type": "Language",
      "name": "Russian",
      "alternateName": "ru"
    }
  ],
  "alumniOf": {
    "@type": "EducationalOrganization",
    "name": "High School"
  }
};
---

<BaseLayout title={c.metaTitle} description={c.metaDescription} localized>
  <!-- JSON-LD Schema for Person -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <div class="about-container">
    <Breadcrumb items={[{ label: c.breadcrumbHome, href: getLocalizedPath('/', lang) }, { label: c.breadcrumbAbout }]} />
    <header class="about-header">
      <h1>{c.h1}</h1>
      <p class="header-subtitle">{c.headerSubtitle}</p>

      <div class="contact-info-header">
        <span class="contact-label">{c.contactLabel}</span>
        <a href="mailto:alexpruteanu@hotmail.com" class="contact-email">alexpruteanu@hotmail.com</a>
      </div>

      <div class="social-links">
        <a href="https://github.com/xander1421" target="_blank" rel="noopener">{c.socialGithub}</a>
        <a href="https://linkedin.com/in/alexandru-prt" target="_blank" rel="noopener">{c.socialLinkedin}</a>
        <a href="/chatter-waitlist">{c.socialChatter}</a>
      </div>
    </header>

    <section class="summary-section">
      <h2>{c.summaryHeading}</h2>
      <p class="summary-text">
        {c.summaryText}
      </p>
    </section>

    <section class="skills-section">
      <h2>{c.skillsHeading}</h2>
      <div class="skills-grid">
        <div class="skill-category cloud">
          <h3><span class="icon">☁️</span> <Fragment set:html={c.skillCloud} /></h3>
          <div class="skill-tags">
            <span class="skill-tag">AWS</span>
            <span class="skill-tag">GCP</span>
            <span class="skill-tag">Terraform</span>
            <span class="skill-tag">Helm</span>
            <span class="skill-tag">Ansible</span>
          </div>
        </div>
        <div class="skill-category cicd">
          <h3><span class="icon">🚀</span> <Fragment set:html={c.skillCicd} /></h3>
          <div class="skill-tags">
            <span class="skill-tag">Jenkins</span>
            <span class="skill-tag">GitHub Actions</span>
            <span class="skill-tag">CircleCI</span>
            <span class="skill-tag">Spinnaker</span>
          </div>
        </div>
        <div class="skill-category containers">
          <h3><span class="icon">📦</span> <Fragment set:html={c.skillContainers} /></h3>
          <div class="skill-tags">
            <span class="skill-tag">Docker</span>
            <span class="skill-tag">Kubernetes</span>
            <span class="skill-tag">Docker Swarm</span>
          </div>
        </div>
        <div class="skill-category monitoring">
          <h3><span class="icon">📊</span> <Fragment set:html={c.skillMonitoring} /></h3>
          <div class="skill-tags">
            <span class="skill-tag">Datadog</span>
            <span class="skill-tag">Grafana</span>
            <span class="skill-tag">Prometheus</span>
            <span class="skill-tag">SonarQube</span>
          </div>
        </div>
        <div class="skill-category languages">
          <h3><span class="icon">💻</span> <Fragment set:html={c.skillLanguages} /></h3>
          <div class="skill-tags">
            <span class="skill-tag">Python</span>
            <span class="skill-tag">Bash</span>
            <span class="skill-tag">PostgreSQL</span>
            <span class="skill-tag">MySQL</span>
            <span class="skill-tag">Redis</span>
          </div>
        </div>
        <div class="skill-category security">
          <h3><span class="icon">🔒</span> <Fragment set:html={c.skillSecurity} /></h3>
          <div class="skill-tags">
            <span class="skill-tag">IAM & RBAC</span>
            <span class="skill-tag">Secrets Management</span>
            <span class="skill-tag">SSL/TLS</span>
            <span class="skill-tag">Security Groups</span>
            <span class="skill-tag">Encryption</span>
          </div>
        </div>
      </div>
    </section>

    <section class="experience-section">
      <h2>{c.experienceHeading}</h2>

      {c.jobs.map((job) => (
        <div class="job">
          <div class="job-header">
            <div>
              <h3>{job.title}</h3>
              <p class="company">{job.company}</p>
            </div>
            <span class="period">{job.period}</span>
          </div>
          <ul class="achievements">
            {job.achievements.map((achievement) => (
              <li>{achievement}</li>
            ))}
          </ul>
          {'tech' in job && job.tech && (
            <p class="tech-stack"><strong>{c.experienceTechLabel}</strong> {job.tech}</p>
          )}
        </div>
      ))}
    </section>

    <section class="additional-info">
      <div class="info-grid">
        <div class="info-item">
          <h3>{c.educationHeading}</h3>
          <p class="degree">{c.educationDegree}</p>
        </div>
        <div class="info-item">
          <h3>{c.languagesHeading}</h3>
          <ul class="languages-list">
            {c.languages.map((language) => (
              <li>{language.name} <span class="level">{language.level}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <h2 set:html={c.ctaHeading}></h2>
      <p>{c.ctaText}</p>
      <div class="cta-buttons">
        <a href="mailto:alexpruteanu@hotmail.com" class="cta-button">{c.ctaContact}</a>
        <a href="/blog" class="cta-button secondary">{c.ctaBlog}</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .about-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .about-header {
    text-align: center;
    margin-bottom: 4rem;
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 2px solid rgba(0, 255, 204, 0.2);
  }

  .about-header h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .header-subtitle {
    font-size: 1.2rem;
    color: var(--color-text-dim);
    margin-bottom: 1rem;
  }

  .social-links {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .social-links a {
    color: var(--color-primary);
    text-decoration: none;
    padding: 0.6rem 1.5rem;
    border: 2px solid var(--color-primary);
    font-family: 'Share Tech Mono', monospace;
    transition: all 0.3s ease;
  }

  .social-links a:hover {
    background: var(--color-primary);
    color: var(--color-bg);
  }

  .contact-info-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin: 1.5rem 0;
    font-size: 1rem;
  }

  .contact-label {
    color: var(--color-text-dim);
    font-family: 'Share Tech Mono', monospace;
    font-weight: 600;
  }

  .contact-email {
    color: var(--color-primary);
    text-decoration: none;
    font-family: 'Share Tech Mono', monospace;
    transition: all 0.3s ease;
    padding: 0.4rem 1rem;
    border: 1px solid rgba(0, 255, 204, 0.3);
    background: rgba(0, 255, 204, 0.05);
  }

  .contact-email:hover {
    background: rgba(0, 255, 204, 0.15);
    border-color: var(--color-primary);
  }

  section {
    margin-bottom: 4.5rem;
  }

  section h2 {
    font-size: 2rem;
    color: var(--color-primary);
    margin-bottom: 2rem;
    border-bottom: 2px solid rgba(0, 255, 204, 0.2);
    padding-bottom: 0.8rem;
  }

  .summary-text {
    font-size: 1.15rem;
    line-height: 1.9;
    color: var(--color-text);
    padding: 2rem;
    background: rgba(0, 255, 204, 0.03);
    border-left: 4px solid var(--color-primary);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2.5rem;
  }

  .skill-category {
    padding: 1.5rem;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.3);
    border: 2px solid;
    transition: all 0.3s ease;
  }

  .skill-category:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
  }

  .skill-category h3 {
    font-size: 1.1rem;
    color: var(--color-text);
    margin-bottom: 1.2rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .skill-category .icon {
    font-size: 1.5rem;
  }

  /* Cloud category - Cyan/Blue */
  .skill-category.cloud {
    border-color: rgb(0, 200, 255);
    background: rgba(0, 200, 255, 0.05);
  }

  .skill-category.cloud h3 {
    color: rgb(0, 200, 255);
  }

  .skill-category.cloud .skill-tag {
    background: rgba(0, 200, 255, 0.08);
    border-color: rgba(0, 200, 255, 0.3);
    color: rgb(0, 200, 255);
  }

  .skill-category.cloud .skill-tag:hover {
    background: rgba(0, 200, 255, 0.2);
    border-color: rgb(0, 200, 255);
  }

  /* CI/CD category - Orange */
  .skill-category.cicd {
    border-color: rgb(255, 150, 50);
    background: rgba(255, 150, 50, 0.05);
  }

  .skill-category.cicd h3 {
    color: rgb(255, 150, 50);
  }

  .skill-category.cicd .skill-tag {
    background: rgba(255, 150, 50, 0.08);
    border-color: rgba(255, 150, 50, 0.3);
    color: rgb(255, 150, 50);
  }

  .skill-category.cicd .skill-tag:hover {
    background: rgba(255, 150, 50, 0.2);
    border-color: rgb(255, 150, 50);
  }

  /* Containers category - Purple */
  .skill-category.containers {
    border-color: rgb(150, 100, 255);
    background: rgba(150, 100, 255, 0.05);
  }

  .skill-category.containers h3 {
    color: rgb(150, 100, 255);
  }

  .skill-category.containers .skill-tag {
    background: rgba(150, 100, 255, 0.08);
    border-color: rgba(150, 100, 255, 0.3);
    color: rgb(150, 100, 255);
  }

  .skill-category.containers .skill-tag:hover {
    background: rgba(150, 100, 255, 0.2);
    border-color: rgb(150, 100, 255);
  }

  /* Monitoring category - Olive Green */
  .skill-category.monitoring {
    border-color: rgb(128, 140, 80);
    background: rgba(128, 140, 80, 0.08);
  }

  .skill-category.monitoring h3 {
    color: rgb(170, 185, 120);
  }

  .skill-category.monitoring .skill-tag {
    background: rgba(128, 140, 80, 0.12);
    border-color: rgba(170, 185, 120, 0.4);
    color: rgb(170, 185, 120);
  }

  .skill-category.monitoring .skill-tag:hover {
    background: rgba(128, 140, 80, 0.25);
    border-color: rgb(170, 185, 120);
  }

  /* Languages category - Dark Navy Blue */
  .skill-category.languages {
    border-color: rgb(25, 55, 109);
    background: rgba(25, 55, 109, 0.15);
  }

  .skill-category.languages h3 {
    color: rgb(100, 150, 255);
  }

  .skill-category.languages .skill-tag {
    background: rgba(25, 55, 109, 0.2);
    border-color: rgba(100, 150, 255, 0.4);
    color: rgb(150, 180, 255);
  }

  .skill-category.languages .skill-tag:hover {
    background: rgba(25, 55, 109, 0.35);
    border-color: rgb(100, 150, 255);
  }

  /* Security category - Brownish */
  .skill-category.security {
    border-color: rgb(180, 120, 80);
    background: rgba(180, 120, 80, 0.08);
  }

  .skill-category.security h3 {
    color: rgb(220, 170, 120);
  }

  .skill-category.security .skill-tag {
    background: rgba(180, 120, 80, 0.12);
    border-color: rgba(220, 170, 120, 0.4);
    color: rgb(220, 170, 120);
  }

  .skill-category.security .skill-tag:hover {
    background: rgba(180, 120, 80, 0.25);
    border-color: rgb(220, 170, 120);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .skill-tag {
    padding: 0.5rem 1rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    border-radius: 4px;
    font-weight: 500;
    border: 1px solid;
  }

  .job {
    margin-bottom: 3.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(0, 255, 204, 0.1);
  }

  .job:last-child {
    border-bottom: none;
  }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    gap: 1.5rem;
  }

  .job-header h3 {
    font-size: 1.4rem;
    color: var(--color-primary);
    margin: 0 0 0.5rem 0;
  }

  .company {
    font-size: 1.05rem;
    color: var(--color-text-dim);
    margin: 0;
    font-family: 'Share Tech Mono', monospace;
  }

  .period {
    font-family: 'Share Tech Mono', monospace;
    color: var(--color-text-dim);
    font-size: 0.95rem;
    white-space: nowrap;
  }

  .achievements {
    list-style: none;
    padding-left: 0;
  }

  .achievements li {
    position: relative;
    padding-left: 1.8rem;
    margin-bottom: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    font-size: 1.05rem;
  }

  .achievements li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-size: 1.3rem;
  }

  .tech-stack {
    margin-top: 1.5rem;
    padding: 0.75rem 1rem;
    background: rgba(0, 255, 204, 0.05);
    border-left: 3px solid var(--color-primary);
    font-size: 0.9rem;
    color: var(--color-text-dim);
    font-family: 'Share Tech Mono', monospace;
    line-height: 1.6;
  }

  .tech-stack strong {
    color: var(--color-primary);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
  }

  .info-item h3 {
    font-size: 1.3rem;
    color: var(--color-primary);
    margin-bottom: 1.2rem;
  }

  .degree {
    font-weight: bold;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }

  .institution {
    color: var(--color-text-dim);
    line-height: 1.6;
  }

  .languages-list {
    list-style: none;
    padding: 0;
  }

  .languages-list li {
    padding: 0.8rem 0;
    border-bottom: 1px solid rgba(0, 255, 204, 0.1);
    color: var(--color-text);
    font-size: 1.05rem;
  }

  .languages-list li:last-child {
    border-bottom: none;
  }

  .level {
    color: var(--color-text-dim);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.9rem;
    margin-left: 0.5rem;
  }

  .cta-section {
    text-align: center;
    padding: 3.5rem 2rem;
    background: rgba(0, 255, 204, 0.03);
    border: 2px solid rgba(0, 255, 204, 0.2);
    margin-top: 4rem;
  }

  .cta-section h2 {
    border: none;
    margin-bottom: 1rem;
  }

  .cta-section p {
    color: var(--color-text-dim);
    margin-bottom: 2.5rem;
    font-size: 1.1rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-button {
    padding: 1rem 2.5rem;
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    border: 2px solid var(--color-primary);
    background: var(--color-primary);
    color: var(--color-bg);
    font-size: 0.95rem;
  }

  .cta-button:hover {
    background: transparent;
    color: var(--color-primary);
  }

  .cta-button.secondary {
    background: transparent;
    color: var(--color-primary);
  }

  .cta-button.secondary:hover {
    background: var(--color-primary);
    color: var(--color-bg);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .about-container {
      padding: 1.5rem 1rem;
    }

    .about-header h1 {
      font-size: 2.5rem;
    }

    .header-subtitle {
      font-size: 1.1rem;
    }

    section h2 {
      font-size: 1.7rem;
    }

    .job-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .skills-grid,
    .info-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .summary-text {
      font-size: 1.05rem;
      padding: 1.5rem;
    }

    .achievements li {
      font-size: 1rem;
    }

    .cta-section {
      padding: 2.5rem 1.5rem;
    }

    .cta-buttons {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
    }
  }
</style>
