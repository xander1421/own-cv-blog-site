---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../Breadcrumb.astro';
import { getServices } from '../../data/services';
import { getLocalizedPath, useTranslations, type Lang } from '../../i18n/ui';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const services = getServices(lang);

const title = t('svc.metaTitle');
const description = t('svc.metaDescription');
const siteUrl = 'https://alexpruteanu.cloud';

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": services.map((s, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${siteUrl}${getLocalizedPath(`/services/${s.slug}`, lang)}`,
    "name": s.title,
  })),
};
---

<BaseLayout title={title} description={description} type="website" localized>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <div class="services-index">
    <Breadcrumb items={[{ label: t('breadcrumb.home'), href: getLocalizedPath('/', lang) }, { label: t('svc.kicker') }]} />
    <div class="svc-index-header">
      <span class="kicker">{t('svc.kicker')}</span>
      <h1>{t('svc.h1')}</h1>
      <p>{t('svc.lead')}</p>
      <a href="https://cal.eu/alexpruteanu" class="cta-primary">{t('svc.bookDiscovery')}</a>
    </div>

    {[
      { key: 'devops', label: t('svc.groupDevopsLabel'), blurb: t('svc.groupDevopsBlurb') },
      { key: 'product', label: t('svc.groupProductLabel'), blurb: t('svc.groupProductBlurb') },
    ].map((group) => (
      <section class="svc-group">
        <div class="svc-group-head">
          <h2 class="svc-group-title">{group.label}</h2>
          <p class="svc-group-blurb">{group.blurb}</p>
        </div>
        <div class="svc-cards">
          {services.filter((s) => s.category === group.key).map((s) => (
            <a class="svc-card" href={getLocalizedPath(`/services/${s.slug}`, lang)}>
              <span class="svc-card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
              </span>
              <strong>{s.nav}</strong>
              <span class="svc-card-h">{s.h1}</span>
              <span class="svc-card-lead">{s.lead}</span>
              <span class="svc-card-go" set:html={t('svc.learnMore')}></span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .services-index {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3.5rem 2rem 5rem;
  }

  .kicker {
    display: inline-block;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .svc-index-header {
    max-width: 720px;
    margin-bottom: 3.5rem;
  }

  .svc-group {
    margin-bottom: 3.5rem;
  }

  .svc-group-head {
    border-top: 1px solid rgba(0, 255, 204, 0.12);
    padding-top: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .svc-group-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 0.35rem;
  }

  .svc-group-blurb {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-text-dim);
    margin: 0;
  }

  .svc-index-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin: 0 0 1.25rem;
    background: linear-gradient(100deg, #e0e0e0 30%, var(--color-primary) 75%, #00bfff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .svc-index-header p {
    font-size: 1.2rem;
    line-height: 1.65;
    color: var(--color-text-dim);
    margin: 0 0 2rem;
  }

  .cta-primary {
    display: inline-block;
    padding: 1rem 2rem;
    background: var(--color-primary);
    color: #06201b;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    border-radius: 8px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 255, 204, 0.3);
  }

  .svc-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .svc-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 2rem;
    border: 1px solid rgba(0, 255, 204, 0.15);
    border-radius: 12px;
    background: rgba(0, 255, 204, 0.02);
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .svc-card:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 255, 204, 0.45);
    box-shadow: 0 12px 32px rgba(0, 255, 204, 0.12);
  }

  .svc-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    margin-bottom: 0.5rem;
    border-radius: 12px;
    border: 1px solid rgba(0, 255, 204, 0.3);
    background: rgba(0, 255, 204, 0.06);
    color: var(--color-primary);
    box-shadow: 0 0 22px rgba(0, 255, 204, 0.15);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .svc-card-icon svg {
    width: 26px;
    height: 26px;
  }

  .svc-card:hover .svc-card-icon {
    transform: scale(1.08);
    box-shadow: 0 0 28px rgba(0, 255, 204, 0.3);
  }

  .svc-card strong {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .svc-card-h {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.25;
  }

  .svc-card-lead {
    color: var(--color-text-dim);
    line-height: 1.6;
    font-size: 0.95rem;
    flex-grow: 1;
  }

  .svc-card-go {
    color: var(--color-primary);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .services-index { padding: 2.5rem 1.5rem 3.5rem; }
  }
</style>
