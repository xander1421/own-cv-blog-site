---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../Breadcrumb.astro';
import PostCard from '../PostCard.astro';
import { getCollection } from 'astro:content';
import { getLocalizedPath, type Lang } from '../../i18n/ui';
import { getProjectsContent } from '../../i18n/content/projects';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const c = getProjectsContent(lang);

const REPO = 'https://github.com/xander1421/chatter';

function readingTime(body: string): number {
  const words = (body ?? '')
    .replace(/```[\s\S]*?```/g, '')
    .replace(/[#*_~`>\-]/g, '')
    .trim()
    .split(/\s+/)
    .filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}

const CHATTER_SLUGS = [
  'from-react-to-rust-native-journey',
  'signal-protocol-implementation-in-chatter',
  'anonymous-inbox-implementation-in-chatter',
  'why-i-chose-monolithic-architecture-for-chatter',
];
const allPosts = await getCollection('blog');
const chatterPosts = CHATTER_SLUGS
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p))
  .map((post) => ({ post, readingTime: readingTime(post.body ?? '') }));

const title = c.chatterMetaTitle;
const description = c.chatterMetaDescription;
---

<BaseLayout title={title} description={description} type="article" localized>
  <article class="case">
    <Breadcrumb items={[{ label: c.chatterBreadcrumbHome, href: getLocalizedPath('/', lang) }, { label: c.chatterBreadcrumbProjects, href: getLocalizedPath('/projects', lang) }, { label: c.chatterBreadcrumbChatter }]} />

    <div class="case-head">
      <span class="kicker" set:html={c.chatterKicker}></span>
      <h1 set:html={c.chatterH1}></h1>
      <p class="lead" set:html={c.chatterLead}></p>
    </div>

    <ul class="case-stats">
      {c.chatterStats.map((s) => (
        <li><strong>{s.n}</strong><span>{s.label}</span></li>
      ))}
    </ul>

    <section class="case-block">
      <h2 set:html={c.chatterHardHeading}></h2>
      <ul class="case-list">
        {c.chatterHardProblems.map((p) => <li>{p}</li>)}
      </ul>
    </section>

    <section class="case-block">
      <h2 set:html={c.chatterStackHeading}></h2>
      <div class="stack-grid">
        {c.chatterStack.map((s) => (
          <div class="stack-row">
            <strong>{s.group}</strong>
            <span>{s.items}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="case-block">
      <div class="case-block-head">
        <h2 set:html={c.chatterBlogHeading}></h2>
        <a href={REPO} target="_blank" rel="noopener" class="gh-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <Fragment set:html={c.chatterGithubLink} />
        </a>
      </div>
      <div class="case-posts">
        {chatterPosts.map(({ post, readingTime }) => (
          <PostCard post={post} readingTime={readingTime} />
        ))}
      </div>
    </section>

    <section class="case-block">
      <h2 set:html={c.chatterWhyHeading}></h2>
      <p class="case-p">
        <Fragment set:html={c.chatterWhyP1} /> <a href={getLocalizedPath('/services/idea-to-production', lang)}>{c.chatterWhyLink1}</a>,
        <a href={getLocalizedPath('/services/building-blocks', lang)}>{c.chatterWhyLink2}</a>,
        <a href={getLocalizedPath('/services/architecture-review', lang)}>{c.chatterWhyLink3}</a>{c.chatterWhyAnd}
        <a href={getLocalizedPath('/services/ai-app-audit', lang)}>{c.chatterWhyLink4}</a>{c.chatterWhyTail}
      </p>
      <p class="case-note" set:html={c.chatterNote}></p>
    </section>

    <section class="case-cta">
      <h2 set:html={c.chatterCtaHeading}></h2>
      <p set:html={c.chatterCtaBody}></p>
      <a href="https://cal.eu/alexpruteanu" class="cta-primary" set:html={c.chatterCtaButton}></a>
    </section>
  </article>
</BaseLayout>

<style>
  .case {
    max-width: 820px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  .kicker {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .case-head h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin: 0 0 1.25rem;
    background: linear-gradient(100deg, #e0e0e0 30%, var(--color-primary) 75%, #00bfff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .lead {
    font-size: 1.2rem;
    line-height: 1.65;
    color: var(--color-text-dim);
    margin: 0;
  }

  .case-stats {
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  .case-stats li {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.25rem;
    border: 1px solid rgba(0, 255, 204, 0.15);
    border-radius: 10px;
    background: rgba(0, 255, 204, 0.03);
  }

  .case-stats strong {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .case-stats span {
    font-size: 0.85rem;
    color: var(--color-text-dim);
    line-height: 1.4;
  }

  .case-block {
    margin-top: 3.5rem;
  }

  .case-block h2 {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 1.5rem;
  }

  .case-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .case-list li {
    position: relative;
    padding-left: 1.8rem;
    color: var(--color-text-dim);
    line-height: 1.6;
  }

  .case-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .case-block-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .case-block-head h2 {
    margin: 0;
  }

  .gh-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-primary);
    text-decoration: none;
  }

  .gh-link:hover {
    text-decoration: underline;
  }

  .case-posts {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    .case-posts {
      grid-template-columns: 1fr;
    }
  }

  .stack-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .stack-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid rgba(0, 255, 204, 0.08);
  }

  .stack-row strong {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary);
  }

  .stack-row span {
    color: var(--color-text-dim);
    line-height: 1.5;
  }

  .case-p {
    color: var(--color-text-dim);
    line-height: 1.7;
    font-size: 1.05rem;
    margin: 0;
  }

  .case-p a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .case-p a:hover {
    text-decoration: underline;
  }

  .case-note {
    margin: 1.25rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-dim);
    opacity: 0.8;
  }

  .case-cta {
    margin-top: 4rem;
    padding: 2.5rem;
    text-align: center;
    border: 1px solid rgba(0, 255, 204, 0.15);
    border-radius: 12px;
    background: rgba(0, 255, 204, 0.04);
  }

  .case-cta h2 {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 0.75rem;
  }

  .case-cta p {
    color: var(--color-text-dim);
    margin: 0 0 1.75rem;
  }

  .cta-primary {
    display: inline-block;
    padding: 1rem 2rem;
    background: var(--color-primary);
    color: #06201b;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    border-radius: 8px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 255, 204, 0.3);
  }

  @media (max-width: 768px) {
    .case { padding: 2rem 1.5rem 3.5rem; }
    .stack-row { grid-template-columns: 1fr; gap: 0.25rem; }
  }
</style>
