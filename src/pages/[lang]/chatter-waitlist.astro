---
import ChatterWaitlist from '../../components/pages/ChatterWaitlist.astro';
import { nonDefaultLocales, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return nonDefaultLocales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
---

<ChatterWaitlist lang={lang} />
