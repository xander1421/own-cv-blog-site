---
import ServiceDetail from '../../components/pages/ServiceDetail.astro';
import { SERVICE_META } from '../../data/services';
import { getLangFromUrl } from '../../i18n/ui';

export function getStaticPaths() {
  return SERVICE_META.map((s) => ({ params: { service: s.slug } }));
}

const { service } = Astro.params;
const lang = getLangFromUrl(Astro.url);
---

<ServiceDetail lang={lang} slug={service} />
