---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { SERVICES } from '../../data/services';

const title = 'DevOps & Cloud Consulting Services';
const description =
  'DevOps and cloud consulting: cloud migration, Kubernetes, cost optimization, CI/CD, plus architecture review, AI-app audits, and idea-to-production builds.';
const siteUrl = 'https://alexpruteanu.cloud';

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": SERVICES.map((s, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${siteUrl}/services/${s.slug}`,
    "name": s.title,
  })),
};
---

<BaseLayout title={title} description={description} type="website">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <div class="services-index">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Services' }]} />
    <div class="svc-index-header">
      <span class="kicker">Services</span>
      <h1>From keeping production boring to shipping your whole product</h1>
      <p>
        DevOps and cloud is the day job — migrations, Kubernetes, cost, CI/CD. But I
        also review architecture, audit AI-built apps, and take ideas all the way to
        shipped. Pick where it hurts most.
      </p>
      <a href="https://cal.eu/alexpruteanu" class="cta-primary">Book a free discovery call</a>
    </div>

    {[
      { key: 'devops', label: 'DevOps & Cloud', blurb: 'The main spin — keep production fast, cheap, and boring.' },
      { key: 'product', label: 'Product, Architecture & Build', blurb: 'Take an idea to a real, secure, shipped app — and de-risk the AI-built ones.' },
    ].map((group) => (
      <section class="svc-group">
        <div class="svc-group-head">
          <h2 class="svc-group-title">{group.label}</h2>
          <p class="svc-group-blurb">{group.blurb}</p>
        </div>
        <div class="svc-cards">
          {SERVICES.filter((s) => s.category === group.key).map((s) => (
            <a class="svc-card" href={`/services/${s.slug}`}>
              <span class="svc-card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
              </span>
              <strong>{s.nav}</strong>
              <span class="svc-card-h">{s.h1}</span>
              <span class="svc-card-lead">{s.lead}</span>
              <span class="svc-card-go">Learn more →</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .services-index {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3.5rem 2rem 5rem;
  }

  .kicker {
    display: inline-block;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .svc-index-header {
    max-width: 720px;
    margin-bottom: 3.5rem;
  }

  .svc-group {
    margin-bottom: 3.5rem;
  }

  .svc-group-head {
    border-top: 1px solid rgba(0, 255, 204, 0.12);
    padding-top: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .svc-group-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 0.35rem;
  }

  .svc-group-blurb {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-text-dim);
    margin: 0;
  }

  .svc-index-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin: 0 0 1.25rem;
    background: linear-gradient(100deg, #e0e0e0 30%, var(--color-primary) 75%, #00bfff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .svc-index-header p {
    font-size: 1.2rem;
    line-height: 1.65;
    color: var(--color-text-dim);
    margin: 0 0 2rem;
  }

  .cta-primary {
    display: inline-block;
    padding: 1rem 2rem;
    background: var(--color-primary);
    color: #06201b;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    border-radius: 8px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 255, 204, 0.3);
  }

  .svc-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .svc-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 2rem;
    border: 1px solid rgba(0, 255, 204, 0.15);
    border-radius: 12px;
    background: rgba(0, 255, 204, 0.02);
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .svc-card:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 255, 204, 0.45);
    box-shadow: 0 12px 32px rgba(0, 255, 204, 0.12);
  }

  .svc-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    margin-bottom: 0.5rem;
    border-radius: 12px;
    border: 1px solid rgba(0, 255, 204, 0.3);
    background: rgba(0, 255, 204, 0.06);
    color: var(--color-primary);
    box-shadow: 0 0 22px rgba(0, 255, 204, 0.15);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .svc-card-icon svg {
    width: 26px;
    height: 26px;
  }

  .svc-card:hover .svc-card-icon {
    transform: scale(1.08);
    box-shadow: 0 0 28px rgba(0, 255, 204, 0.3);
  }

  .svc-card strong {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .svc-card-h {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.25;
  }

  .svc-card-lead {
    color: var(--color-text-dim);
    line-height: 1.6;
    font-size: 0.95rem;
    flex-grow: 1;
  }

  .svc-card-go {
    color: var(--color-primary);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .services-index { padding: 2.5rem 1.5rem 3.5rem; }
  }
</style>
